{
  "name": "feathershot",
  "version": "1.2.1",
  "description": "Premium, feature-rich screenshot tool for Windows inspired on Greenshot",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --linux --publish never",
    "build": "electron-builder --win --linux --publish never",
    "publish": "electron-builder --win --linux --publish always"
  },
  "keywords": [
    "screenshot",
    "greenshot",
    "windows",
    "electron"
  ],
  "author": "Aeeryin",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeeryin/Feathershot.git"
  },
  "license": "MIT",
  "build": {
    "appId": "com.feathershot.app",
    "productName": "Feathershot",
    "publish": [
      {
        "provider": "github",
        "owner": "aeeryin",
        "repo": "Feathershot",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "main.png",
      "artifactName": "Feathershot-${version}-windows.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "main.png",
      "identity": null,
      "artifactName": "Feathershot-${version}-macos.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "main.png",
      "artifactName": "Feathershot-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "Feathershot-${version}-windows.${ext}",
      "shortcutName": "Feathershot"
    },
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3"
  }
}